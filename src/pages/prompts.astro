---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROMPTS, getPromptsByCategory } from '../lib/prompts.js';
const byCategory = getPromptsByCategory();
const categories = Object.entries(byCategory);
const total = PROMPTS.length;
const catCount = categories.length;
---
<BaseLayout title="Prompts - Free Prompt Studio" description={`${total} prompts across ${catCount} categories.`} wide>
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-accent">Prompts</p>
      <h1 class="mt-1 text-2xl sm:text-3xl font-semibold tracking-tight text-primary">Ready-to-Use Prompts</h1>
      <p class="mt-1.5 text-sm text-secondary"><span class="font-medium text-primary">{total}</span> prompts across <span class="font-medium text-primary">{catCount}</span> categories. Click a card to reveal the full text, then copy it.</p>
    </div>
    <div class="relative w-full sm:w-64 shrink-0">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" id="prompt-search" placeholder="Search prompts..." class="w-full rounded-lg border border-strong bg-surface-2 px-3 py-2 text-sm text-primary outline-none transition-colors focus:border-[var(--border-strong)]" style="padding: 0.5rem 0.75rem 0.5rem 2.1rem" autocomplete="off" />
    </div>
  </div>

  <div class="mt-6 flex flex-wrap gap-1.5" id="category-filters">
    <button class="pill-filter active" data-cat="all">All <span class="ml-1 text-tertiary font-normal">{total}</span></button>
    {categories.map(([cat, prompts]) => (
      <button class="pill-filter" data-cat={cat}>{cat} <span class="ml-1 text-tertiary font-normal">{prompts.length}</span></button>
    ))}
  </div>

  <div class="mt-8 space-y-12" id="prompts-container">
    {categories.map(([cat, prompts]) => (
      <section class="prompt-category" data-category={cat}>
        <div class="flex items-center gap-3 mb-4">
          <span class="h-px flex-1 bg-border"></span>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-tertiary shrink-0">{cat} <span class="font-normal text-muted">({prompts.length})</span></h2>
          <span class="h-px flex-1 bg-border"></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
          {prompts.map(p => (
            <div class="prompt-card group relative">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <h3 class="text-sm font-medium text-primary truncate">{p.title}</h3>
                  <p class="mt-1 text-xs text-secondary leading-relaxed line-clamp-2">{p.desc}</p>
                </div>
                <button class="copy-btn shrink-0 mt-0.5" data-prompt={p.prompt} title="Copy prompt">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                </button>
              </div>
              <div class="prompt-body hidden mt-3 pt-3 border-t border-default">
                <pre class="text-xs text-secondary leading-relaxed whitespace-pre-wrap font-mono">{[...p.prompt.matchAll(/.{1,80}/g)].map(line => line[0]).join('\n')}</pre>
                <button class="copy-inline-btn mt-3 w-full py-2 rounded-lg text-xs font-medium bg-accent text-white hover:bg-accent-hover transition-colors" data-prompt={p.prompt}>Copy Prompt</button>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>

  <div class="mt-12 py-6 text-center text-xs text-tertiary border-t border-default">
    {total} prompts · click to reveal · copy to use
  </div>

  <script>
    // ── Search filter ──
    const searchInput = document.getElementById('prompt-search');
    const allCards = document.querySelectorAll('.prompt-card');
    const sections = document.querySelectorAll('.prompt-category');

    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      allCards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = q && !text.includes(q) ? 'none' : '';
      });
      sections.forEach(section => {
        const visible = [...section.querySelectorAll('.prompt-card')].some(c => c.style.display !== 'none');
        section.style.display = visible ? '' : 'none';
      });
    });

    // ── Category filter pills ──
    const filterBtns = document.querySelectorAll('.pill-filter');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.dataset.cat;
        sections.forEach(section => {
          section.style.display = cat === 'all' || section.dataset.category === cat ? '' : 'none';
        });
        if (searchInput.value) searchInput.value = '';
      });
    });

    // ── Card click to reveal ──
    document.addEventListener('click', (e) => {
      const card = e.target.closest('.prompt-card');
      if (card && !e.target.closest('.copy-btn') && !e.target.closest('.copy-inline-btn')) {
        card.querySelector('.prompt-body').classList.toggle('hidden');
        return;
      }
      const btn = e.target.closest('.copy-btn') || e.target.closest('.copy-inline-btn');
      if (btn) {
        const prompt = btn.dataset.prompt;
        if (prompt) {
          navigator.clipboard.writeText(prompt).catch(() => {});
          const orig = btn.innerHTML;
          btn.innerHTML = `<svg class="h-4 w-4 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
          if (btn.classList.contains('copy-inline-btn')) {
            btn.textContent = 'Copied!';
            btn.style.background = 'var(--accent)';
          }
          setTimeout(() => { btn.innerHTML = orig; if (btn.classList.contains('copy-inline-btn')) btn.style.background = ''; }, 1200);
        }
      }
    });
  </script>
</BaseLayout>