---
import '../styles/global.css';
---

<html lang="en" class="">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Free Prompt Studio - AI Prompt Generator, Templates & Analyzer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="PromptGen" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="description" content="Free AI Prompt Generator - turn any idea into a structured, optimized prompt for ChatGPT, Claude, Gemini, and more. Templates, analyzer, and sanitizer included." />
  </head>
  <body>
    <!-- ═══════ HEADER (full width) ═══════ -->
    <header class="border-b border-default">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4 sm:gap-6">
          <button class="flex items-center gap-2.5 shrink-0 cursor-pointer bg-transparent border-none text-left py-3 sm:py-0" style="min-height:44px" id="logo-btn">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5" fill="none" class="text-tertiary" />
              <path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-primary" />
            </svg>
            <span class="text-base font-semibold tracking-tight text-primary">Free Prompt Studio</span>
          </button>
          <nav class="hidden lg:flex items-center gap-1">
            <button class="nav-link active" data-nav="generator">Generator</button>
            <button class="nav-link" data-nav="templates">Templates</button>
            <button class="nav-link" data-nav="analyzer">Analyzer</button>
            <a href="/prompts" class="nav-link">Prompts</a>
          </nav>
        </div>
        <div class="flex items-center gap-2 sm:gap-3">
          <button class="hamburger" id="hamburger-btn" aria-label="Menu" aria-expanded="false">
            <svg id="menu-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            <svg id="menu-close-icon" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
          <button class="theme-toggle shrink-0" id="theme-toggle" title="Toggle theme" aria-label="Toggle theme">
            <svg class="w-4 h-4" id="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="5" />
              <line x1="12" y1="1" x2="12" y2="3" />
              <line x1="12" y1="21" x2="12" y2="23" />
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
              <line x1="1" y1="12" x2="3" y2="12" />
              <line x1="21" y1="12" x2="23" y2="12" />
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
            </svg>
            <svg class="w-4 h-4 hidden" id="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
        </div>
      </div>
      <!-- Mobile drawer overlay -->
      <div id="menu-overlay" class="fixed inset-0 bg-black/50 z-40 lg:hidden" data-open="false"></div>

      <!-- Mobile drawer -->
      <div id="mobile-menu" class="fixed top-0 right-0 h-full w-72 max-w-[80vw] z-50 bg-surface border-l border-default lg:hidden shadow-2xl" data-open="false">
        <div class="flex items-center justify-between px-4 h-14 border-b border-default">
          <span class="text-sm font-semibold text-primary">Menu</span>
          <button id="menu-close-btn" class="cursor-pointer bg-transparent border-none p-2 text-tertiary hover:text-primary transition-colors rounded-lg min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Close menu">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
        <nav class="flex flex-col p-3 gap-1">
          <button class="nav-link active" data-nav="generator">Generator</button>
          <button class="nav-link" data-nav="templates">Templates</button>
          <button class="nav-link" data-nav="analyzer">Analyzer</button>
          <a href="/prompts" class="nav-link">Prompts</a>
        </nav>
      </div>
    </header>

    <!-- ═══════ MAIN CONTENT (centered) ═══════ -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <!-- Page heading -->
      <div class="pt-6 sm:pt-8 pb-3 sm:pb-4">
        <h1 class="text-xl sm:text-2xl font-semibold tracking-tight text-primary">AI Prompt Generator - <span class="gradient-text">Turn any idea into a powerful prompt</span></h1>
        <p class="mt-1 text-sm text-tertiary">Describe what you need, pick a framework, and get a structured prompt ready to use. All in your browser, always free.</p>
      </div>

      <!-- Method tabs -->
      <div class="border-b border-default flex" id="method-tabs">
        <button class="tab-btn active shrink-0" data-method="generator">
          <span class="hidden sm:inline">AI Prompt Generator</span>
          <span class="sm:hidden">Generator</span>
        </button>
        <button class="tab-btn shrink-0" data-method="templates">
          <span class="hidden sm:inline">Prompt Templates Library</span>
          <span class="sm:hidden">Templates</span>
        </button>
        <button class="tab-btn shrink-0" data-method="analyzer">
          <span class="hidden sm:inline">Prompt Analyzer & Optimizer</span>
          <span class="sm:hidden">Analyzer</span>
        </button>
      </div>

      <!-- Panels -->
      <div class="mt-5 sm:mt-6">

        <!-- ━━━━━━ METHOD 1: GENERATOR ━━━━━━ -->
        <div id="panel-generator" class="method-panel">

          <!-- Quick input with suggestion chips -->
          <div class="mb-4 sm:mb-5">
            <div class="card">
              <div class="card-header">What do you need a prompt for?</div>
              <div class="card-content space-y-3">
                <textarea class="input-mono min-h-[80px] sm:min-h-[90px]" id="quick-input" placeholder="e.g. Write a blog post about remote work productivity tips...">I want a prompt to </textarea>
                <div class="flex flex-wrap gap-1.5" id="suggestion-chips">
                  <button class="btn-ghost chip" data-text="Write a blog post about">📝 Blog post</button>
                  <button class="btn-ghost chip" data-text="Draft a professional email about">📧 Email</button>
                  <button class="btn-ghost chip" data-text="Create social media content for">📱 Social media</button>
                  <button class="btn-ghost chip" data-text="Write persuasive sales copy for">💰 Sales copy</button>
                  <button class="btn-ghost chip" data-text="Explain in simple terms">🧠 Explain</button>
                  <button class="btn-ghost chip" data-text="Brainstorm creative ideas for">💡 Brainstorm</button>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6">
            <div class="lg:col-span-2 space-y-4 sm:space-y-5">

              <div class="card">
                <div class="card-header">Prompt Framework</div>
                <div class="card-content">
                  <select class="input-default w-full" id="framework-selector">
                    <option value="CO-STAR">CO-STAR — Context, Obj., Style, Tone, Audience, Response</option>
                    <option value="RISEN">RISEN — Role, Instructions, Steps, End Goal, Narrowing</option>
                    <option value="CRAFT">CRAFT — Context, Role, Action, Format, Target</option>
                    <option value="ORACLE">ORACLE — Outcome, Request, Action, Context, Example</option>
                    <option value="RACE">RACE — Role, Action, Context, Example</option>
                    <option value="CARE">CARE — Context, Action, Result, Example</option>
                    <option value="APE">APE — Action, Purpose, Expectation</option>
                    <option value="CREATE">CREATE — Context, Role, Examples, Action, Task, Expect.</option>
                    <option value="TAG">TAG — Task, Action, Goal</option>
                    <option value="CREO">CREO — Context, Role, Examples, Output</option>
                    <option value="RISE">RISE — Role, Input, Steps, Expectation</option>
                    <option value="PAIN">PAIN — Problem, Audience, Implications, Need</option>
                    <option value="COAST">COAST — Context, Obj., Actions, Scenario, Task</option>
                    <option value="Freeform">Freeform — No specific structure</option>
                  </select>
                  <p class="mt-2 text-xs text-tertiary" id="framework-desc">Context, Objective, Style, Tone, Audience, Response</p>
                </div>
              </div>

              <div class="card">
                <div class="card-header">Target Model</div>
                <div class="card-content">
                  <div class="flex flex-wrap gap-1.5 sm:gap-2" id="model-selector">
                  </div>
                  <p class="mt-2 text-xs text-tertiary" id="model-desc">Optimized for GPT-4o</p>
                </div>
              </div>

              <div class="card">
                <div class="card-header flex items-center justify-between">
                  <span>Variables</span>
                  <span class="badge" id="field-count">6 fields</span>
                </div>
                <div class="card-content space-y-3" id="variable-fields">
                </div>
              </div>

              <div class="card">
                <div class="card-header flex items-center justify-between">
                  <span>Compiled Prompt</span>
                  <div class="flex items-center gap-2">
                    <button class="btn-ghost" id="btn-gen-copy">Copy</button>
                    <button class="btn-ghost" id="btn-gen-share">Share URL</button>
                  </div>
                </div>
                <div class="p-3">
                  <textarea class="input-mono min-h-[180px] sm:min-h-[200px] rounded-none border-0" id="gen-output" readonly placeholder="Fill in the variables above to generate a structured prompt..."></textarea>
                </div>
              </div>
            </div>

            <div class="space-y-4 sm:space-y-5">
              <div class="card">
                <div class="card-header">Tips</div>
                <div class="card-content-sm space-y-3 text-xs text-secondary leading-relaxed">
                  <p><strong class="text-primary">1.</strong> Start by describing what you need in the box above.</p>
                  <p><strong class="text-primary">2.</strong> Choose a prompt framework that matches your task.</p>
                  <p><strong class="text-primary">3.</strong> Fill in the variables to customize your prompt.</p>
                  <p><strong class="text-primary">4.</strong> Copy the compiled prompt and use it with any AI.</p>
                  <div class="pt-2 border-t border-default">
                    <p class="text-tertiary">Need to clean up AI output? <button class="underline cursor-pointer bg-transparent border-none text-accent hover:text-accent-hover inline-block py-4 min-w-[44px]" id="toggle-sanitizer">Open Sanitizer →</button></p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Collapsible Sanitizer -->
          <div class="mt-4 hidden" id="sanitizer-section">
            <div class="card">
              <div class="card-header flex items-center justify-between">
                <span>Response Text Sanitizer</span>
                <button class="btn-ghost" id="close-sanitizer">✕</button>
              </div>
              <div class="card-content-sm space-y-3">
                <textarea class="input-mono min-h-[80px] sm:min-h-[100px]" id="sani-input" placeholder="Paste raw AI output here..."></textarea>
                <div class="flex flex-wrap gap-1.5">
                  <button class="btn-ghost" id="sani-backticks">Strip Backticks</button>
                  <button class="btn-ghost" id="sani-fluff">Remove AI Fluff</button>
                  <button class="btn-ghost" id="sani-spaces">Collapse Spaces</button>
                  <button class="btn-ghost" id="sani-markdown">Strip Markdown</button>
                  <button class="btn-ghost" id="sani-quotes">Fix Smart Quotes</button>
                  <button class="btn-ghost" id="sani-unicode">Strip Unicode</button>
                </div>
                <div class="relative">
                  <textarea class="input-mono min-h-[80px] sm:min-h-[100px]" id="sani-output" readonly placeholder="Cleaned output will appear here..."></textarea>
                  <button class="btn-ghost absolute right-1.5 top-1.5" id="sani-copy">Copy</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ━━━━━━ METHOD 2: TEMPLATES ━━━━━━ -->
        <div id="panel-templates" class="method-panel hidden">
          <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 sm:gap-6">
            <div class="lg:col-span-1">
              <div class="card">
                <div class="card-header">Categories</div>
                <div class="max-h-[300px] sm:max-h-none overflow-y-auto p-2 space-y-1" id="category-list">
                </div>
              </div>
            </div>
            <div class="lg:col-span-3 space-y-4 sm:space-y-5">
              <div class="card">
                <div class="card-header flex items-center justify-between">
                  <span id="template-category-label">Writing & Content</span>
                  <span class="badge" id="template-count">0 templates</span>
                </div>
                <div class="card-content">
                  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3" id="template-grid">
                  </div>
                </div>
              </div>
              <div class="card hidden" id="template-detail">
                <div class="card-header flex items-center justify-between">
                  <span id="template-detail-title">Template</span>
                  <button class="btn-ghost" id="btn-template-back">Back</button>
                </div>
                <div class="card-content space-y-3" id="template-fields">
                </div>
                <div class="p-3">
                  <textarea class="input-mono min-h-[120px] sm:min-h-[150px] rounded-none border-0" id="template-output" readonly placeholder="Fill template fields to generate a prompt..."></textarea>
                </div>
                <div class="border-t border-default px-3 py-2 flex justify-end gap-2">
                  <button class="btn-ghost" id="btn-template-copy">Copy</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ━━━━━━ METHOD 3: ANALYZER ━━━━━━ -->
        <div id="panel-analyzer" class="method-panel hidden">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6">
            <div class="lg:col-span-2 space-y-4 sm:space-y-5">
              <div class="card">
                <div class="card-header">Paste Your Prompt</div>
                <div class="card-content space-y-3">
                  <textarea class="input-mono min-h-[200px] sm:min-h-[250px]" id="analyzer-input" placeholder="Paste any prompt here to analyze its quality and get suggestions for improvement..."></textarea>
                  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
                    <button class="btn-primary" id="btn-analyze">Analyze</button>
                    <span class="text-xs text-tertiary" id="analyzer-char-count">0 characters</span>
                  </div>
                </div>
              </div>

              <div class="card hidden" id="analyzer-improved-card">
                <div class="card-header">Suggested Improvement</div>
                <div class="p-3">
                  <textarea class="input-mono min-h-[150px] sm:min-h-[200px] rounded-none border-0" id="analyzer-improved" readonly></textarea>
                </div>
                <div class="border-t border-default px-3 py-2 flex flex-wrap justify-end gap-2">
                  <button class="btn-ghost" id="btn-analyzer-copy">Copy</button>
                  <button class="btn-ghost" id="btn-analyzer-use">Use in Generator</button>
                </div>
              </div>
            </div>

            <div class="space-y-4 sm:space-y-5">
              <div class="card" id="analyzer-score-card">
                <div class="card-header">Quality Score</div>
                <div class="card-content flex flex-col items-center">
                  <div class="score-ring" id="score-ring">
                    <svg width="100" height="100" viewBox="0 0 120 120" class="sm:w-[120px] sm:h-[120px]" aria-hidden="true">
                      <circle class="score-ring-bg" cx="60" cy="60" r="52" />
                      <circle class="score-ring-fill" id="score-ring-fill" cx="60" cy="60" r="52"
                        stroke="currentColor"
                        stroke-dasharray="326.7"
                        stroke-dashoffset="326.7" />
                    </svg>
                    <span class="absolute text-xl sm:text-2xl font-semibold text-primary" id="score-value">--</span>
                  </div>
                  <p class="mt-3 text-sm text-tertiary text-center" id="score-label">Enter a prompt to begin</p>
                  <div class="mt-4 w-full space-y-2">
                    <div class="flex justify-between text-xs text-secondary">
                      <span>Words</span>
                      <span id="score-words">0</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="card">
                <div class="card-header">Criteria Breakdown</div>
                <div class="card-content-sm space-y-2" id="criteria-list">
                  <p class="text-xs text-tertiary">Run an analysis to see results.</p>
                </div>
              </div>

              <div class="card">
                <div class="card-header">Suggestions</div>
                <div class="card-content-sm space-y-2" id="suggestions-list">
                  <p class="text-xs text-tertiary">Run an analysis to see suggestions.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- ═══════ USEFUL PROMPTS ═══════ -->
      <div class="mt-10 sm:mt-12 pt-5 sm:pt-6 border-t border-default" id="section-prompts">
        <h2 class="text-lg sm:text-xl font-semibold tracking-tight text-primary">Useful Ready-to-Use Prompts</h2>
        <p class="mt-1 text-sm text-tertiary">Click any prompt to reveal the full text, then copy it. <a href="/prompts" class="text-accent hover:text-accent-hover underline inline-block py-3">View all prompts &rarr;</a></p>
        <div class="mt-4 sm:mt-5 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3" id="prompts-section"></div>
      </div>

      <!-- ═══════ FOOTER ═══════ -->
      <footer class="mt-10 sm:mt-12 border-t border-default">
        <div class="py-5 sm:py-6">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
            <div class="flex items-center gap-2 text-xs text-tertiary">
              <span>Free Prompt Studio</span>
              <span class="text-border">·</span>
              <span>100% browser · Free</span>
            </div>
            <nav class="flex items-center gap-4 text-xs text-secondary">
              <a href="/terms" class="hover:text-primary transition-colors py-4 min-w-[44px] text-center">Terms</a>
              <a href="/privacy" class="hover:text-primary transition-colors py-4 min-w-[44px] text-center">Privacy</a>
              <a href="/faq" class="hover:text-primary transition-colors py-4 min-w-[44px] text-center">FAQ</a>
            </nav>
          </div>
          <p class="mt-3 text-[10px] text-tertiary text-center sm:text-left">100% static. Runs entirely in your browser. No data is sent to any server.</p>
        </div>
      </footer>
    </div>

    <script type="module">
      // ── Theme toggle ──
      (() => {
        const html = document.documentElement;
        const themeToggle = document.getElementById('theme-toggle');
        const sunIcon = document.getElementById('theme-icon-sun');
        const moonIcon = document.getElementById('theme-icon-moon');
        function setTheme(theme) {
          html.classList.toggle('light', theme === 'light');
          html.classList.toggle('dark', theme !== 'light');
          sunIcon.classList.toggle('hidden', theme === 'light');
          moonIcon.classList.toggle('hidden', theme !== 'light');
          try { localStorage.setItem('theme', theme); } catch {}
        }
        const saved = (() => { try { return localStorage.getItem('theme'); } catch { return null; } })();
        setTheme(saved === 'light' ? 'light' : 'dark');
        themeToggle.addEventListener('click', () => setTheme(html.classList.contains('light') ? 'dark' : 'light'));
      })();

      import { FRAMEWORKS, FRAMEWORK_META, compileFramework, getModels } from '../lib/frameworks.js';
      import { TEMPLATE_CATEGORIES, TEMPLATES, getTemplatesByCategory, getTemplateById } from '../lib/templates.js';
      import { analyzePrompt } from '../lib/analyzer.js';
      import { stripBackticks, removeFluff, collapseSpaces, stripMarkdown, fixSmartQuotes, stripUnicode } from '../lib/sanitizer.js';
      import { pushStateToURL, getStateFromURL } from '../lib/urlEncoder.js';
      import { PROMPTS, getPromptsByCategory } from '../lib/prompts.js';

      // ── Mobile drawer ──
      const hamburgerBtn = document.getElementById('hamburger-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuOverlay = document.getElementById('menu-overlay');
      const menuCloseBtn = document.getElementById('menu-close-btn');
      const menuIcon = document.getElementById('menu-icon');
      const menuCloseIcon = document.getElementById('menu-close-icon');

      function openMenu() {
        mobileMenu.setAttribute('data-open', 'true');
        menuOverlay.setAttribute('data-open', 'true');
        hamburgerBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        menuIcon.classList.add('hidden');
        menuCloseIcon.classList.remove('hidden');
      }

      function closeMenu() {
        mobileMenu.setAttribute('data-open', 'false');
        menuOverlay.setAttribute('data-open', 'false');
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        menuIcon.classList.remove('hidden');
        menuCloseIcon.classList.add('hidden');
      }

      if (hamburgerBtn && mobileMenu && menuOverlay) {
        hamburgerBtn.addEventListener('click', () => {
          if (mobileMenu.getAttribute('data-open') === 'true') {
            closeMenu();
          } else {
            openMenu();
          }
        });
        menuOverlay.addEventListener('click', closeMenu);
        if (menuCloseBtn) menuCloseBtn.addEventListener('click', closeMenu);
        mobileMenu.querySelectorAll('button, a').forEach(el => {
          el.addEventListener('click', closeMenu);
        });
      }

      // ── Logo scroll-to-top ──
      document.getElementById('logo-btn').addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

      // ── Nav / tab switching ──
      const navLinks = document.querySelectorAll('[data-nav]');
      const methodTabs = document.querySelectorAll('[data-method]');
      const panels = {
        generator: document.getElementById('panel-generator'),
        templates: document.getElementById('panel-templates'),
        analyzer: document.getElementById('panel-analyzer'),
      };

      function switchMethod(method) {
        Object.keys(panels).forEach(key => panels[key].classList.toggle('hidden', key !== method));
        methodTabs.forEach(t => t.classList.toggle('active', t.dataset.method === method));
