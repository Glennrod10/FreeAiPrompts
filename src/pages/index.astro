      function renderFields(framework) {
        const meta = FRAMEWORK_META[framework];
        if (!meta) return;
        frameworkDesc.textContent = meta.full;
        fieldCount.textContent = meta.fields.length + ' fields';
        varFields.innerHTML = meta.fields.map(f => {
          const val = frameworkValues[f.key] || '';
          return `<div class="mb-3">
            <label class="block text-xs font-medium text-secondary mb-1">${f.label}</label>
            <input class="input-default" data-fkey="${f.key}" type="text" value="${val.replace(/"/g, '&quot;')}" placeholder="${f.placeholder}" />
          </div>`;
        }).join('');
        varFields.querySelectorAll('input').forEach(inp => inp.addEventListener('input', e => {
          frameworkValues[e.target.dataset.fkey] = e.target.value;
          compileGenerator();
        }));
        compileGenerator();
      }

      frameworkSelect.addEventListener('change', () => {
        selectedFramework = frameworkSelect.value;
        renderFields(selectedFramework);
      });

      function compileGenerator() {
        genOutput.value = compileFramework(selectedFramework, frameworkValues, selectedModel);
      }

      btnGenCopy.addEventListener('click', async () => {
        if (!genOutput.value) return;
        try { await navigator.clipboard.writeText(genOutput.value); } catch { genOutput.select(); document.execCommand('copy'); }
        const orig = btnGenCopy.textContent;
        btnGenCopy.textContent = 'Copied!';
        setTimeout(() => { btnGenCopy.textContent = orig; }, 1500);
      });

      btnGenShare.addEventListener('click', () => {
        if (!Object.values(frameworkValues).some(v => v && v.trim())) return;
        pushStateToURL({ tool: 'generator', framework: selectedFramework, values: frameworkValues });
